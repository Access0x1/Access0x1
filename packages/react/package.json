{
  "name": "@access0x1/react",
  "version": "0.1.0",
  "description": "viem/wagmi-native React SDK for Access0x1 — a zero-custody, USD-priced crypto payment button you can drop into any React app in under five minutes.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "viem": "^2.35",
    "wagmi": "^3"
  },
  "peerDependenciesMeta": {
    "wagmi": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "happy-dom": "^15.11.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "viem": "^2.35.1",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "access0x1",
    "payments",
    "usdc",
    "viem",
    "wagmi",
    "web3",
    "crypto-checkout"
  ]
}
