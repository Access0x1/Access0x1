{
  "name": "@access0x1/react",
  "version": "0.1.0",
  "description": "viem/wagmi-native React SDK for Access0x1 — a zero-custody, USD-priced crypto payment button you can drop into any React app in under five minutes.",
  "license": "MIT",
  "author": "Access0x1",
  "homepage": "https://github.com/Access0x1/Access0x1/tree/main/packages/react#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Access0x1/Access0x1.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/Access0x1/Access0x1/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepare": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "viem": "^2.35",
    "wagmi": "^2.35 || ^3"
  },
  "peerDependenciesMeta": {
    "wagmi": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.2.17",
    "happy-dom": "^20.10.6",
    "react": "^19.2.7",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "viem": "^2.35.1",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "access0x1",
    "payments",
    "usdc",
    "stablecoin",
    "crypto-checkout",
    "pay-button",
    "viem",
    "wagmi",
    "react",
    "web3",
    "ethereum"
  ]
}
