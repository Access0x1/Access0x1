# {{PROJECT_NAME}} — environment variable NAMES only (no values, no secrets).
#
# Copy this to .env.local (the setup script / create-access0x1 CLI already does this for you) and
# fill the values there. This file is committed; .env.local is NOT (see .gitignore).
# LAW #3: secrets never leave their box.
#
# DOCTRINE / LAW #4 (truth in copy): every slot below is BLANK and OPTIONAL. The router DEFAULTS to
# the CREATE3 mirror (a verifiable, already-deployed address, identical on every chain — see
# access0x1.config.ts) on chains where it is deployed, so a fresh app pays with ZERO env. Set a slot
# only to OVERRIDE that default (your own deploy / a router you trust), or to target a chain where the
# mirror is NOT deployed yet (there the router IS required, and a blank one fails loudly rather than
# calling an empty address — never an invented one). Fill any value from EITHER:
#   - your own deploy broadcast (contracts/DEPLOY.md → broadcast/<chainId>/run-latest.json), OR
#   - the official docs (Circle USDC, Chainlink feeds, Arc RPC) — "confirm from official docs".
#
# NOTE FOR `degit` USERS: the {{CHAIN_NAME}} / {{CHAIN_ID}} / {{ROUTER_ENV}} tokens below are
# substituted by the create-access0x1 CLI. If you used degit directly, the app defaults to Arc
# Testnet (chain 5042002) — a mirrored chain, so checkout works with NOTHING set here.

# =============================================================================
# {{CHAIN_NAME}} ({{CHAIN_ID}}) — your selected chain
# Every slot below is keyed to {{CHAIN_ID}}. The CLI substitutes these tokens for
# your chosen chain (arc / base / zksync / …); degit users get the Arc default
# (5042002). To target a different chain, re-run with `--chain <key>`.
# =============================================================================
# Access0x1Router OVERRIDE (optional). Blank = use the CREATE3 mirror default if this chain is
# mirrored. Fill from your `forge script DeployAll` broadcast, or paste a router you trust.
# (CLI users: {{ROUTER_ENV}} is substituted to NEXT_PUBLIC_ROUTER_ADDRESS_<chainId> for your chosen
#  chain. degit users: this token stays literal — Arc (5042002) is mirrored, so checkout works with
#  nothing set; to override, add NEXT_PUBLIC_ROUTER_ADDRESS_5042002 to .env.local.)
{{ROUTER_ENV}}=

# The allowlisted Circle USDC token on this chain (the default ERC-20 pay-in token).
# confirm at booth (Circle). On Arc, USDC is the NATIVE gas token — you may leave this
# blank to pay natively in USDC (no ERC-20 address needed).
# (degit users: {{CHAIN_ID}} stays literal — use NEXT_PUBLIC_USDC_ADDRESS_5042002 for the Arc default.)
NEXT_PUBLIC_USDC_ADDRESS_{{CHAIN_ID}}=

# Per-chain JSON-RPC endpoint. Leave blank to use the public default; set a keyed RPC for prod.
# Arc public RPC: https://rpc.testnet.arc.network
# (degit users: {{CHAIN_ID}} stays literal — use NEXT_PUBLIC_RPC_URL_5042002 for the Arc default.)
NEXT_PUBLIC_RPC_URL_{{CHAIN_ID}}=

# Default chain the app connects to (substituted to your chosen chain by the CLI; degit users get Arc Testnet = 5042002).
NEXT_PUBLIC_DEFAULT_CHAIN_ID={{CHAIN_ID}}

# =============================================================================
# Chainlink price feeds (USD pricing) — configured ON-CHAIN at deploy time
# =============================================================================
# The router prices USD→token via Chainlink feeds wired at deploy by
# contracts/script/HelperConfig.s.sol. You set the feed addresses THERE (per chain), not here:
#   NATIVE_USD_FEED / USDC_USD_FEED (or the chain-prefixed ARC_* / BASE_SEPOLIA_* variants).
# confirm at booth (Chainlink) — docs.chain.link/data-feeds. Leave blank until confirmed; the
# deploy script SKIPS an unset feed rather than wiring a guess.

# =============================================================================
# Other supported chains — REFERENCE ONLY (commented out)
# =============================================================================
# Your selected chain is wired above. The blocks below name the env vars for the
# OTHER deployed chains, so you can also point the app at them. Uncomment a block
# (and drop the line if it duplicates your selected chain above) to fill it in.
# Base Sepolia (84532)
# NEXT_PUBLIC_ROUTER_ADDRESS_84532=
# NEXT_PUBLIC_USDC_ADDRESS_84532=
# NEXT_PUBLIC_RPC_URL_84532=
# zkSync Sepolia (300)
# NEXT_PUBLIC_ROUTER_ADDRESS_300=
# NEXT_PUBLIC_USDC_ADDRESS_300=
# NEXT_PUBLIC_RPC_URL_300=

# =============================================================================
# Wallet provider — INPUT YOUR DIFFERENCE (pick one; vanilla default = injected)
# =============================================================================
# The scaffold boots on a plain injected wallet (window.ethereum) with ZERO credentials. To use a
# sponsor instead, set NEXT_PUBLIC_WALLET_PROVIDER + that provider's id below. The SDK is
# auth-agnostic, so switching never touches the checkout (see app/access0x1.config.ts →
# INTEGRATION_SEAMS for every sponsor seam).
#   injected (default) | dynamic | privy | wagmi
NEXT_PUBLIC_WALLET_PROVIDER=
# Dynamic hosted wallets — confirm at booth (Dynamic).
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=
# Privy embedded wallets — confirm at booth (Privy).
NEXT_PUBLIC_PRIVY_APP_ID=
# Social logins — clean, Google-native sign-in (comma-separated, e.g. google,apple), powered by your
# wallet provider (Dynamic/Privy) underneath. Empty = wallet-only. Enable the connector in the
# provider dashboard. confirm at booth (Google).
NEXT_PUBLIC_SOCIAL_LOGINS=

# =============================================================================
# Earnings privacy — OPTIONAL (hide merchant revenue from competitors)
# =============================================================================
# Public chains expose every settlement, so a merchant's revenue is visible to competitors. Set to
# `true` to route through the private-settlement path (designated provider: Privy). Off by default —
# vanilla settlements are public + verifiable.
NEXT_PUBLIC_EARNINGS_PRIVACY=

# =============================================================================
# ENS pay-to-name — OPTIONAL (off by default)
# =============================================================================
# Show an extra checkout field where a buyer can type a human name (e.g. alice.eth) that is resolved
# to a recipient/payout address ON THIS SETTLEMENT CHAIN before paying. Resolution runs against
# Ethereum Mainnet (where ENS lives) using the chain's ENSIP-11 coinType, never invents an address, and
# never falls back to a mainnet address on an L2 (see app/ens.ts). Leave all blank ⇒ the field is
# hidden and checkout is unchanged.
#
# Turn it on explicitly, OR implicitly by setting either knob below.
NEXT_PUBLIC_ENS_PAY_TO_NAME=
# ENS Universal Resolver OVERRIDE. Blank ⇒ viem targets the canonical resolver by name (no baked
# address). Set only to a resolver you confirmed on Etherscan. confirm at booth (ENS).
NEXT_PUBLIC_ENS_RESOLVER=
# Ethereum Mainnet RPC used ONLY for the read-only ENS resolution call (never for settlement).
# Blank ⇒ viem's public transport.
NEXT_PUBLIC_MAINNET_RPC_URL=

# =============================================================================
# Server-only secrets (NEVER prefixed NEXT_PUBLIC_; NEVER committed)
# =============================================================================
# Anthropic API key for any server-side AI features you add. Server-only.
CLAUDE_API_KEY=
