# EditorConfig helps maintain consistent coding styles across editors and IDEs.
# https://editorconfig.org
root = true

# Defaults for every file.
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

# Solidity and Vyper use a 4-space indent.
[*.{sol,vy}]
indent_size = 4

# JavaScript, TypeScript, JSON, and YAML use a 2-space indent (the default).
[*.{js,mjs,cjs,jsx,ts,tsx,json,yml,yaml}]
indent_size = 2

# Makefiles require literal tabs in recipe lines.
[{Makefile,*.mk}]
indent_style = tab

# Markdown: trailing whitespace can be a meaningful hard line break.
[*.md]
trim_trailing_whitespace = false
