# Access0x1 — deploy env template. COPY to .env (gitignored) and fill per chain.
# NEVER put a private key here: signing is keystore-only (cast wallet import deployer);
# this file documents PUBLIC addresses + RPC/verifier URLs only (security.md, law #4 truth).
# Every live-chain token/feed address is `# CONFIRM` until verified at the booth/docs —
# DeployAll skips any configure call whose address resolves to address(0), so a partial,
# not-yet-confirmed broadcast is safe and never pollutes the live router with a guess.

# ── Keystore (cast wallet import deployer — never a raw key) ──────────────────
DEPLOYER=0x...                         # `cast wallet address --account deployer` (PUBLIC)
ROUTER_OWNER=0x...                     # Ownable2Step admin; defaults to the broadcaster if unset
DEPLOY_PAYMENT_LANES=true              # set true to also deploy Access0x1Lanes (ERC-6909) + authorize the router as a minter

# ── Arc testnet (chainId 5042002) ─────────────────────────────────────────────
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network   # CONFIRM at Arc/Circle booth
ARC_SCAN_VERIFIER_URL=                                 # CONFIRM at Arc booth (Blockscout-style verifier URL)
ARC_PLATFORM_TREASURY=0x...            # your burner treasury wallet (required — vm.envAddress reverts if unset)
ARC_PLATFORM_FEE_BPS=100               # 1.00% default (optional; falls back to 100)
ARC_NATIVE_USD_FEED=                   # native/USD Chainlink feed on Arc — CONFIRM at Chainlink/Arc booth; leave blank if absent
ARC_USDC_ADDRESS=                      # Arc ERC-20 USDC — CONFIRM at Circle booth (native USDC = 18 dec; ERC-20 may differ)
ARC_USDC_USD_FEED=                     # Chainlink USDC/USD on Arc — CONFIRM; may not exist on testnet

# ── Base Sepolia (chainId 84532) ──────────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASESCAN_API_KEY=                      # from basescan.org (verify step only)
BASE_SEPOLIA_PLATFORM_TREASURY=0x...   # required — vm.envAddress reverts if unset
BASE_SEPOLIA_PLATFORM_FEE_BPS=100
BASE_SEPOLIA_NATIVE_USD_FEED=          # ETH/USD Chainlink feed — confirm from docs.chain.link/data-feeds
BASE_SEPOLIA_USDC_ADDRESS=             # Circle USDC on Base Sepolia (6 dec) — confirm from Circle docs
BASE_SEPOLIA_USDC_USD_FEED=            # USDC/USD Chainlink feed on Base Sepolia

# ── zkSync Sepolia (chainId 300) ──────────────────────────────────────────────
ZKSYNC_SEPOLIA_RPC_URL=https://sepolia.era.zksync.dev
ZKSYNC_SEPOLIA_PLATFORM_TREASURY=0x... # required — vm.envAddress reverts if unset
ZKSYNC_SEPOLIA_PLATFORM_FEE_BPS=100
ZKSYNC_SEPOLIA_NATIVE_USD_FEED=        # ETH/USD Chainlink feed on zkSync Sepolia — CONFIRM
ZKSYNC_SEPOLIA_USDC_ADDRESS=           # USDC on zkSync Sepolia — CONFIRM from zkSync docs
ZKSYNC_SEPOLIA_USDC_USD_FEED=          # USDC/USD feed on zkSync Sepolia — CONFIRM

# ── Shared (fallback for any chainId not matched by a named branch) ────────────
PLATFORM_TREASURY=0x...                # required for the fallback (_liveConfigFromEnv)
PLATFORM_FEE_BPS=100
NATIVE_USD_FEED=
USDC_ADDRESS=
USDC_USD_FEED=
SEPOLIA_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=
OPTIMISM_SEPOLIA_RPC_URL=
ETHERSCAN_API_KEY=
ARBISCAN_API_KEY=
OPTIMISM_API_KEY=
