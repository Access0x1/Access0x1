# Access0x1 — deploy env template. COPY to .env (gitignored) and fill per chain.
# NEVER put a private key here: signing is keystore-only (cast wallet import deployer);
# this file documents PUBLIC addresses + RPC/verifier URLs only (security.md, law #4 truth).
# Every live-chain token/feed address is `# CONFIRM` until verified at the booth/docs —
# DeployAll skips any configure call whose address resolves to address(0), so a partial,
# not-yet-confirmed broadcast is safe and never pollutes the live router with a guess.
#
# ✓ VERIFIED testnet USDC + Chainlink feed addresses (Circle + Chainlink official sources,
#   re-checked on-chain 2026-06-17) live in docs/CHAIN-ADDRESSES.md — it has a paste-ready
#   block for zkSync/Polygon-Amoy/Avalanche-Fuji/BNB/Linea/Unichain/Worldchain/Celo Sepolia.
#   Chains with no official USDC/feed deploy bare (router + stack); a feed can be added later.
#
# RPC — the <CHAIN>_RPC_URL values below default to PUBLIC endpoints (rate-limited; fine for a
#   single deploy, flaky across 20+ chains). For the multi-chain broadcast, REPLACE each with your
#   Alchemy or Tenderly URL — far more reliable, and Tenderly adds tx simulation + a verifier:
#     Alchemy : https://<net>.g.alchemy.com/v2/<ALCHEMY_KEY>   (eth-sepolia, arb-sepolia, opt-sepolia,
#               base-sepolia, polygon-amoy, worldchain-sepolia, unichain-sepolia, zksync-sepolia, …)
#     Tenderly: https://<net>.gateway.tenderly.co/<TENDERLY_ACCESS_KEY>
#   These URLs EMBED an API key ⇒ SECRET: keep them in .env only, NEVER commit (guard-enforced).
#   (Owner logs in to grab them — see .claude/rules/accounts.md.)

# ── Keystore (cast wallet import <name> — never a raw key) ────────────────────
DEPLOYER_ACCOUNT=deployer              # the cast keystore NAME the deploy targets sign with —
                                       # set to what you actually imported (`cast wallet list`):
                                       # e.g. DEPLOYER_ACCOUNT=default  or  =SEPOLIA_KEY
DEPLOYER=0x...                         # `cast wallet address --account $DEPLOYER_ACCOUNT` (PUBLIC)
ROUTER_OWNER=0x...                     # Ownable2Step admin; defaults to the broadcaster if unset
DEPLOY_PAYMENT_LANES=true              # set true to also deploy Access0x1Lanes (ERC-6909) + authorize the router as a minter
# ── Mirror-deployer guard (opt-in; CREATE3 addresses are derived from the SIGNER) ──
ENFORCE_MIRROR_DEPLOYER=               # set =true on a REAL mirror deploy: a signer != the canonical
                                       # mirror EOA then fails loud instead of silently landing at a
                                       # different address set. Leave unset/false for local + ad-hoc runs.
MIRROR_DEPLOYER=                       # the expected mirror signer; defaults to the canonical EOA
                                       # (0xA121e1eF31BbF0826aa67dc01e7977e80Af58D73) the manifest was computed for

# ── Arc testnet (chainId 5042002) ─────────────────────────────────────────────
# Arc's native gas token IS USDC (18 dec). There is no published Chainlink USDC/USD feed
# on Arc testnet. Run `script/DeployArcUsdFeed.s.sol` BEFORE `make deploy-arc` to deploy
# a $1.00 MockV3Aggregator, then paste its address into ARC_USDC_USD_FEED below.
# See docs/ARC-DEPLOY.md for the full step-by-step runbook.
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network   # CONFIRM at Arc/Circle booth
ARC_SCAN_VERIFIER_URL=https://testnet.arcscan.app/api?  # Blockscout verifier — CONFIRM URL at booth
ARC_PLATFORM_TREASURY=0x...            # your burner treasury wallet (required — vm.envAddress reverts if unset)
ARC_PLATFORM_FEE_BPS=100               # 1.00% default (optional; falls back to 100)
ARC_NATIVE_USD_FEED=                   # native/USD Chainlink feed on Arc — CONFIRM at Chainlink/Arc booth; leave blank if absent
ARC_USDC_ADDRESS=                      # Arc ERC-20 USDC — CONFIRM at Circle booth (native USDC = 18 dec; ERC-20 may differ)
# ARC_USDC_USD_FEED: no Chainlink feed on Arc testnet. Deploy the $1.00 stand-in first:
#   forge script script/DeployArcUsdFeed.s.sol --rpc-url $ARC_TESTNET_RPC_URL \
#     --account deployer --sender $DEPLOYER --broadcast \
#     --verify --verifier blockscout --verifier-url https://testnet.arcscan.app/api? \
#     --gas-price 20000000000 -vvvv
# Then paste the printed address here (set BEFORE make deploy-arc):
ARC_USDC_USD_FEED=                     # fill with address from DeployArcUsdFeed.s.sol output

# ── 0G Galileo testnet (chainId 16602) ────────────────────────────────────────
# Native gas token is 0G (18 dec), NOT USDC — no native/USD feed exists (never invent one).
# 0G has NO Chainlink Data Feeds: deploy a $1.00 USDC/USD MockV3Aggregator first, then paste it:
