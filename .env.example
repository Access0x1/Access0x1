GALILEO_PLATFORM_FEE_BPS=100           # 1.00% default (optional)
GALILEO_NATIVE_USD_FEED=               # leave blank — 0G has no native/USD feed
GALILEO_USDC_ADDRESS=                  # real ERC-20 USDC on 0G if/when one exists (else blank)
GALILEO_USDC_USD_FEED=                 # fill with the $1 mock feed address (deploy-usd-mock-feed)

