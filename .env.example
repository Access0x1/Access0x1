# ── Multi-token checkout — EXTRA pay tokens (DeployAll allowlist + price-feed) ─
# A buyer may pay in ANY allowlisted coin, each USD-priced via its own Chainlink
# <token>/USD feed. USDC is the DEFAULT and is wired by the per-chain USDC vars
# above (ARC_USDC_ADDRESS / *_USDC_USD_FEED) — it is NOT re-listed here. For each
# coin below, DeployAll calls setTokenAllowed(addr) + setPriceFeed(addr, feed),
# SKIPPING any pair whose ADDR is blank/address(0) (not booth-confirmed yet) — a
# guess never reaches the live router. An ADDR set WITHOUT its USD_FEED is
# allowlisted but unpriced: quote() then reverts Access0x1__InvalidPrice (loud),
# never a silent misprice. These are PUBLIC tokens/standards. CONFIRM each at the
# booth/docs before filling (the deploy is re-runnable as confirmations land).
# NOTE: these are read per RUN (one chain at a time, matching --rpc-url); set the
# values for the chain you are broadcasting to.
TOKEN_WETH_ADDR=                       # CONFIRM — Wrapped Ether ERC-20 on this chain
TOKEN_WETH_USD_FEED=                   # CONFIRM — Chainlink ETH/USD feed (WETH tracks ETH)
TOKEN_LINK_ADDR=                       # CONFIRM — Chainlink (LINK) ERC-20 on this chain
TOKEN_LINK_USD_FEED=                   # CONFIRM — Chainlink LINK/USD feed
TOKEN_UNI_ADDR=                        # CONFIRM — Uniswap (UNI) ERC-20 on this chain
TOKEN_UNI_USD_FEED=                    # CONFIRM — Chainlink UNI/USD feed
TOKEN_ENS_ADDR=                        # CONFIRM — Ethereum Name Service (ENS) ERC-20 on this chain
TOKEN_ENS_USD_FEED=                    # CONFIRM — Chainlink ENS/USD feed (may not exist on testnet)
TOKEN_DAI_ADDR=                        # CONFIRM — Dai (DAI) ERC-20 on this chain
TOKEN_DAI_USD_FEED=                    # CONFIRM — Chainlink DAI/USD feed
TOKEN_WBTC_ADDR=                       # CONFIRM — Wrapped Bitcoin (WBTC) ERC-20 (8 dec) on this chain
TOKEN_WBTC_USD_FEED=                   # CONFIRM — Chainlink WBTC/USD or BTC/USD feed

# ── Shared (fallback for any chainId not matched by a named branch) ────────────
PLATFORM_TREASURY=0x...                # required for the fallback (_liveConfigFromEnv)
PLATFORM_FEE_BPS=100
NATIVE_USD_FEED=
USDC_ADDRESS=
USDC_USD_FEED=
SEPOLIA_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=
OPTIMISM_SEPOLIA_RPC_URL=
ETHERSCAN_API_KEY=
ARBISCAN_API_KEY=
OPTIMISM_API_KEY=
ZKSYNC_VERIFIER_URL=                                    # CONFIRM at zkSync booth (block-explorer verification API)

# ── ENS merchant identity (ENSIP-19 read + Namestone gasless subname write) ───
# OPTIONAL seams, both fail-soft: unset ⇒ OFF (no-op), never fabricated.
# WRITE — Namestone gasless subnames `<label>.<parent>.eth`:
NAMESTONE_API_KEY=                     # OWNER-FILL — your Namestone API key; blank ⇒ subname issuance OFF (no-op)
ENS_SUBNAME_PARENT=                    # OWNER-FILL — YOUR OWN ENS name as the subname parent (e.g. yourbrand.eth); blank ⇒ OFF
# NAMESTONE_BASE_URL=                  # OPTIONAL override; defaults to the public Namestone API

# ── Featured merchant (web, OPTIONAL) — feature ONE business as the default brand
# Set these to feature one business as the default brand on this deployment: the
# branding store seeds ONE stable row at boot (survives restarts) and the web
# root redirects to that business's branded checkout (/c/<slug>) instead of
# /onboard. BOTH slug and name are required to enable it; blank ⇒ default
# onboarding entry point. Generic example only — never a real company name.
FEATURED_MERCHANT_SLUG=                 # e.g. yourbrand — checkout link tail (/c/yourbrand)
FEATURED_MERCHANT_NAME=                 # e.g. Your Brand — business name shown on checkout
FEATURED_MERCHANT_DESCRIPTION=          # optional — one-line description
FEATURED_MERCHANT_BRAND_COLOR=          # optional — hex brand color (e.g. #6366F1); blank ⇒ default

# ── Funding seam (web) — get USDC into the buyer/agent wallet ──────────────────
# The web app's funding layer (lib/funding + lib/onramp). Set these in web/.env.local
# (see web/.env.example for the full notes); listed here so the deploy template is
# complete. BOTH paths are env-gated + fail-soft: blank ⇒ the funding button is
# HIDDEN, nothing is ever guessed (law #4). NEXT_PUBLIC_* are PUBLIC; ONRAMP_SERVER_KEY
# is SERVER-ONLY and never enters a response/URL.
# One-tap deposit (one-tap crypto funding; SDK @swype-org/deposit, installed at booth):
BLINK_ENABLED=                         # confirm/owner-fill — "true" to enable one-tap deposit
NEXT_PUBLIC_BLINK_APP_ID=              # confirm/owner-fill — public app id for the deposit widget
NEXT_PUBLIC_BLINK_TOKEN=               # optional — delivered token, defaults to USDC
NEXT_PUBLIC_BLINK_CHAIN_ID=            # optional — destination chain id, defaults to the app default
# Fiat on-ramp (provider-agnostic; NONE hardcoded — chosen by ONRAMP_PROVIDER):
ONRAMP_PROVIDER=                       # confirm/owner-fill — one of: coinbase, moonpay, stripe, circle, blink
NEXT_PUBLIC_ONRAMP_BASE_URL=           # confirm/owner-fill — provider hosted-checkout base URL
NEXT_PUBLIC_ONRAMP_APP_ID=             # confirm/owner-fill — provider public app/api id
NEXT_PUBLIC_ONRAMP_ASSET=              # optional — delivered asset, defaults to USDC
NEXT_PUBLIC_ONRAMP_NETWORK=            # optional — provider network slug (e.g. base, ethereum)
ONRAMP_SERVER_KEY=                     # optional/server-only — provider session-minting secret (never NEXT_PUBLIC_)
