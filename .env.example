ETHEREUM_MAINNET_PLATFORM_FEE_BPS=      # optional — defaults to 100 (1.00%) when blank
ETHEREUM_MAINNET_NATIVE_USD_FEED=       # CONFIRM — AUDIT-GATED — ETH/USD feed; blank ⇒ skipped
ETHEREUM_MAINNET_USDC_ADDRESS=          # CONFIRM — AUDIT-GATED — Circle USDC (6 dec); blank ⇒ skipped
ETHEREUM_MAINNET_USDC_USD_FEED=         # CONFIRM — AUDIT-GATED — USDC/USD feed; blank ⇒ skipped

