# ── Multi-token checkout — EXTRA pay tokens (DeployAll allowlist + price-feed) ─
# A buyer may pay in ANY allowlisted coin, each USD-priced via its own Chainlink
# <token>/USD feed. USDC is the DEFAULT and is wired by the per-chain USDC vars
# above (ARC_USDC_ADDRESS / *_USDC_USD_FEED) — it is NOT re-listed here. For each
# coin below, DeployAll calls setTokenAllowed(addr) + setPriceFeed(addr, feed),
# SKIPPING any pair whose ADDR is blank/address(0) (not booth-confirmed yet) — a
# guess never reaches the live router. An ADDR set WITHOUT its USD_FEED is
# allowlisted but unpriced: quote() then reverts Access0x1__InvalidPrice (loud),
# never a silent misprice. These are PUBLIC tokens/standards. CONFIRM each at the
# booth/docs before filling (the deploy is re-runnable as confirmations land).
# NOTE: these are read per RUN (one chain at a time, matching --rpc-url); set the
# values for the chain you are broadcasting to.
TOKEN_WETH_ADDR=                       # CONFIRM — Wrapped Ether ERC-20 on this chain
TOKEN_WETH_USD_FEED=                   # CONFIRM — Chainlink ETH/USD feed (WETH tracks ETH)
TOKEN_LINK_ADDR=                       # CONFIRM — Chainlink (LINK) ERC-20 on this chain
TOKEN_LINK_USD_FEED=                   # CONFIRM — Chainlink LINK/USD feed
TOKEN_UNI_ADDR=                        # CONFIRM — Uniswap (UNI) ERC-20 on this chain
TOKEN_UNI_USD_FEED=                    # CONFIRM — Chainlink UNI/USD feed
TOKEN_ENS_ADDR=                        # CONFIRM — Ethereum Name Service (ENS) ERC-20 on this chain
TOKEN_ENS_USD_FEED=                    # CONFIRM — Chainlink ENS/USD feed (may not exist on testnet)
TOKEN_DAI_ADDR=                        # CONFIRM — Dai (DAI) ERC-20 on this chain
TOKEN_DAI_USD_FEED=                    # CONFIRM — Chainlink DAI/USD feed
TOKEN_WBTC_ADDR=                       # CONFIRM — Wrapped Bitcoin (WBTC) ERC-20 (8 dec) on this chain
TOKEN_WBTC_USD_FEED=                   # CONFIRM — Chainlink WBTC/USD or BTC/USD feed

