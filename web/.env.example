# Access0x1 web — Unlink private payout leg env (server-only; never in client bundles).
# Real values are filled at the ETHGlobal booth. NEVER commit a real key.

# Unlink app id — passed to buildDeriveSeedMessage (public, but keep config in one place).
UNLINK_APP_ID=

# Unlink secret API key — server-only; createUnlinkAdmin uses this. NEVER ship to the client.
UNLINK_API_KEY=

# Unlink environment — literal kebab-case "arc-testnet" (NOT camel "arcTestnet",
# which is the Circle Gateway identifier for the SAME chain id 5042002).
UNLINK_ENVIRONMENT=arc-testnet

# Real Arc-testnet USDC token address — copy verbatim from lib/arc-constants.ts /
# the Circle repo at the booth. NEVER an address from memory.
ARC_TESTNET_USDC=

# Server payout key + bound userId for the fromKeys account (transfer/withdraw only,
# no execute = zero custody). Filled at the booth.
UNLINK_PAYOUT_PRIVATE_KEY=
UNLINK_PAYOUT_USER_ID=

# Already set by feat/dynamic-agent — listed here for completeness.
# NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=
