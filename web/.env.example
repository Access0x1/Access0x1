# Access0x1 web — Dynamic AI payment agent (server-side ONLY).
#
# Every var below is read on the server (Next.js route handler / node SDK). NONE of
# these are NEXT_PUBLIC_* — they MUST NOT reach the browser bundle (doctrine
# guardrail #7). This repo is public: never commit real values, only this template.

# Dynamic ----------------------------------------------------------------------
# Same environment id the frontend provider uses (Dynamic dashboard).
DYNAMIC_ENVIRONMENT_ID=
# Server API token (NOT a user JWT). Authenticates the node SDK once per process.
DYNAMIC_AUTH_TOKEN=
# Encrypts the Dynamic MPC client key share. Server-only secret.
WALLET_PASSWORD=
# Persisted after the first createWalletAccount call. Leave blank on first boot;
# the agent creates a wallet and you record its id here so it is reused.
AGENT_WALLET_ID=

# Budget meter -----------------------------------------------------------------
# Daily spend ceiling for the demo agent, in USD (e.g. "5.00"). The never-negative
# meter blocks any call that would push the day's spend over this cap.
AGENT_DAILY_USD_CAP=5.00

# x402 endpoint allowlist (SSRF guard) -----------------------------------------
# Comma-separated list of exact origins (scheme://host[:port]) the agent is
# allowed to pay. A url whose origin is not in this list is rejected with 400.
AGENT_URL_ALLOWLIST=http://localhost:3000
