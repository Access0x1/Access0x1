# Access0x1 web — environment variable NAMES only (no values, no secrets).
# This repo is PUBLIC. Copy to .env.local and fill values there; never commit a
# real key. No contract address is ever hardcoded in source (doctrine guardrail
# #5): every router/USDC address is read from a var below. Every value is
# booth-confirmed; leave a slot blank until that chain's contract is deployed.
#
# ─── THE MINIMAL "YOUR INFO" SET ─────────────────────────────────────────────
# Everything below is OPTIONAL. The app builds and runs with an EMPTY env: the
# default chain is Arc Testnet (5042002), the router defaults to the CREATE3
# mirror, Arc USDC defaults to the chain's native system token, and the RPC
# defaults to the public endpoint — all prewired, zero code. To make a fresh
# clone YOUR branded deployment, set ONLY the "Featured merchant" block below
# (slug + name; color/description/merchant-id optional) — nothing else.
# QUOTING: values containing `#` (hex colors) MUST be quoted — an unquoted `#`
# starts a comment in .env files (FEATURED_MERCHANT_BRAND_COLOR="#E8590C").
# ─────────────────────────────────────────────────────────────────────────────

# =============================================================================
# One-Tag Checkout embed (public/embed.js)
# Baked into the embed by scripts/replace-embed-addrs.js at build time. PUBLIC.
# =============================================================================
# Arc testnet (chainId 5042002) — the embed's default chain
NEXT_PUBLIC_ROUTER_ARC=
NEXT_PUBLIC_USDC_ARC=
# Base Sepolia (chainId 84532)
NEXT_PUBLIC_ROUTER_BASE_SEPOLIA=
NEXT_PUBLIC_USDC_BASE_SEPOLIA=
# zkSync Sepolia (chainId 300)
NEXT_PUBLIC_ROUTER_ZKSYNC_SEPOLIA=
NEXT_PUBLIC_USDC_ZKSYNC_SEPOLIA=

# =============================================================================
# Hosted checkout + dashboard (checkout-web) — PUBLIC NEXT_PUBLIC_*_<chainId>
# =============================================================================
# Dynamic (wallet auth/signing — 4.x)
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=
# C-3: a Dynamic JWT is pinned to this environment by issuer + audience so a token
# minted for a DIFFERENT Dynamic environment/app is rejected. Both default from the
# environment id above (issuer `app.dynamicauth.com/<env>`, audience `<env>`); set
# these ONLY to override if your Dynamic dashboard reports a different iss/aud.
DYNAMIC_JWT_ISSUER=
DYNAMIC_JWT_AUDIENCE=
# Branding WRITE posture. When true, POST /api/branding rejects any write that
# is not backed by a verified Dynamic JWT (fail-closed) — set this in production
# so an unauthenticated caller can never overwrite a tenant's branding. Defaults
# to on whenever NODE_ENV=production; leave blank in dev/booth to keep the
# shape-checked fallback. Accepts true|false.
BRANDING_REQUIRE_VERIFIED_WRITES=
# Arc Testnet (chain id 5042002 — the settlement chain)
NEXT_PUBLIC_ARC_RPC_URL=
NEXT_PUBLIC_ROUTER_ADDRESS_5042002=
NEXT_PUBLIC_USDC_ADDRESS_5042002=
# Base Sepolia (chain id 84532)
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=
NEXT_PUBLIC_ROUTER_ADDRESS_84532=
NEXT_PUBLIC_USDC_ADDRESS_84532=
# Ethereum Sepolia (chain id 11155111) — mirror router + canonical USDC default
# zero-config; override here only to point at a non-default deploy.
NEXT_PUBLIC_ROUTER_ADDRESS_11155111=
NEXT_PUBLIC_USDC_ADDRESS_11155111=
# zkSync Sepolia (chain id 300)
NEXT_PUBLIC_ZKSYNC_SEPOLIA_RPC_URL=
NEXT_PUBLIC_ROUTER_ADDRESS_300=
NEXT_PUBLIC_USDC_ADDRESS_300=
# Default chain the app connects to (one of the ids above)
NEXT_PUBLIC_DEFAULT_CHAIN_ID=5042002
# Optional: The Graph subgraph query URL for the dashboard receipts feed. When
# set, the dashboard reads payment history from the subgraph (fail-soft); when
# unset it falls back to a bounded on-chain getLogs scan. Dormant by default.
NEXT_PUBLIC_ACCESS0X1_SUBGRAPH_URL=

# ── Multi-token checkout — buyer pay-token picker (PUBLIC, per chain) ──────────
# The picker offers any allowlisted coin. USDC is the DEFAULT and uses the
# NEXT_PUBLIC_USDC_ADDRESS_<chainId> vars above (no duplicate). Each EXTRA coin's
# address is NEXT_PUBLIC_TOKEN_<SYM>_<chainId>; its Chainlink feed (optional in
# the UI — the on-chain quote() is the source of truth) is NEXT_PUBLIC_TOKEN_<SYM>_FEED_<chainId>.
# A coin left BLANK on a chain is shown DISABLED in the picker with a
# "not available on this chain" note — never hidden, never a guessed address.
# Mirror the on-chain set wired by DeployAll's TOKEN_<SYM>_ADDR / _USD_FEED.
# Fill ONLY the coins you have allowlisted on that chain's Router. CONFIRM addrs.
# Example (Base Sepolia, chain id 84532) — uncomment + fill the coins you support:
# NEXT_PUBLIC_TOKEN_WETH_84532=
# NEXT_PUBLIC_TOKEN_WETH_FEED_84532=
# NEXT_PUBLIC_TOKEN_LINK_84532=
# NEXT_PUBLIC_TOKEN_LINK_FEED_84532=
# NEXT_PUBLIC_TOKEN_UNI_84532=
# NEXT_PUBLIC_TOKEN_UNI_FEED_84532=
# NEXT_PUBLIC_TOKEN_ENS_84532=
# NEXT_PUBLIC_TOKEN_ENS_FEED_84532=
# NEXT_PUBLIC_TOKEN_DAI_84532=
# NEXT_PUBLIC_TOKEN_DAI_FEED_84532=
# NEXT_PUBLIC_TOKEN_WBTC_84532=
# NEXT_PUBLIC_TOKEN_WBTC_FEED_84532=

# Claude API (server-side ONLY — never in a client bundle or embed.js)
CLAUDE_API_KEY=
# /api/ask rate-limit trust (R-6). Set to "true" ONLY when deployed behind a trusted reverse
# proxy / CDN that sets x-real-ip (or appends the real client IP as the LAST x-forwarded-for hop).
# Blank/false => forwarding headers are NOT trusted (they are client-spoofable) and the limiter
# buckets everyone under one shared key. Never trust the raw FIRST x-forwarded-for value.
ASK_TRUST_PROXY=

# PUBLIC checkout host (optional) — the domain the branded checkout link
# (`{host}/c/{slug}`) is served from, shown on receipts/QR/embed. Leave BLANK to
# use this deploy's own domain (recommended). Set it ONLY when checkout runs on a
# dedicated domain distinct from the dashboard (e.g. pay.example.com). Host only,
# no scheme. Never leave it pointing at a domain you don't control.
NEXT_PUBLIC_CHECKOUT_HOST=

# =============================================================================
# Featured merchant (optional) — feature ONE business as the default brand
# =============================================================================
# Set these to feature one business as the default brand on this deployment:
# the branding store seeds ONE stable row from them at boot (survives restarts)
# and the root redirects to that business's branded checkout (/c/<slug>) instead
# of /onboard. BOTH slug and name are required to enable it; leave blank to keep
# the default onboarding entry point. Generic example only — never a real company.
FEATURED_MERCHANT_SLUG=                # e.g. yourbrand — the checkout link tail (/c/yourbrand)
FEATURED_MERCHANT_NAME=                # e.g. Your Brand — the business name shown on checkout
FEATURED_MERCHANT_DESCRIPTION=         # optional — one-line description
FEATURED_MERCHANT_BRAND_COLOR=         # optional — hex brand color; QUOTE IT ("#6366F1") — an unquoted # starts a comment; blank ⇒ default
FEATURED_MERCHANT_MERCHANT_ID=         # optional — your on-chain merchantId (positive integer from registerMerchant/onboard); set ⇒ the pay card renders live
FEATURED_MERCHANT_CHAIN_ID=            # optional — the chain your featured merchant registered on (e.g. 84532); blank ⇒ the app default chain. Set this when the merchant is NOT on the default chain, so the slug settles on the RIGHT chain.
FEATURED_MERCHANT_CHECKOUT_MODE=       # optional — standard | verified-human | private; blank/unknown ⇒ standard

# =============================================================================
# x402 nanopayment seller / facilitator (arc-x402) — SERVER-ONLY
# =============================================================================
# Seller payout wallet — a plain EOA (later = merchant.access0x1.eth).
SELLER_ADDRESS=
# Server-only: signs Gateway withdraws. NEVER in the repo.
SELLER_PRIVATE_KEY=
# Demo only (fund-gateway + demo-loop): the ephemeral buyer EOA.
BUYER_PRIVATE_KEY=
# Circle Gateway facilitator base (confirm at booth).
CIRCLE_FACILITATOR_URL=https://gateway-api-testnet.circle.com
# Arc Testnet RPC (confirm at booth).
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
# Demo loop base URL + deposit (optional overrides).
DEMO_BASE_URL=http://localhost:3000
DEMO_DEPOSIT=5.00

# ── Per-chain x402 config (PUBLIC, optional) ──────────────────────────────────
# x402 / SessionGrant settlement values are resolved PER CHAIN by lib/x402/config.ts:
# the CAIP-2 network, the settlement USDC, the Gateway Wallet (EIP-712
# verifyingContract), and the facilitator base URL. Chain 5042002 (Arc Testnet)
# ships booth-confirmed DEFAULTS (from lib/arc-constants.ts) — leave these blank to
# keep Arc unchanged. To run x402 on ANOTHER chain, set its four vars (USDC,
# Gateway, facilitator are REQUIRED; network defaults to eip155:<chainId>). A
# missing USDC / Gateway / facilitator is a hard stop — never guessed (law #4).
# NEXT_PUBLIC_X402_NETWORK_<chainId>=        # optional — CAIP-2, defaults to eip155:<chainId>
# NEXT_PUBLIC_X402_USDC_<chainId>=           # required for a non-Arc chain — settlement USDC address
# NEXT_PUBLIC_X402_GATEWAY_<chainId>=        # required for a non-Arc chain — Gateway Wallet (verifyingContract)
# NEXT_PUBLIC_X402_FACILITATOR_URL_<chainId>= # required for a non-Arc chain — verify/settle base URL
# Arc (5042002) overrides — OPTIONAL; blank ⇒ the booth-confirmed defaults are used:
NEXT_PUBLIC_X402_NETWORK_5042002=
NEXT_PUBLIC_X402_USDC_5042002=
NEXT_PUBLIC_X402_GATEWAY_5042002=
NEXT_PUBLIC_X402_FACILITATOR_URL_5042002=

# =============================================================================
# Dynamic AI payment agent (dynamic-agent) — SERVER-ONLY (no NEXT_PUBLIC_*)
# =============================================================================
# Same environment id the frontend provider uses (Dynamic dashboard).
DYNAMIC_ENVIRONMENT_ID=
# Server API token (NOT a user JWT). Authenticates the node SDK once per process.
DYNAMIC_AUTH_TOKEN=
# Encrypts the Dynamic MPC client key share. Server-only secret.
WALLET_PASSWORD=
# Persisted after the first createWalletAccount call. Leave blank on first boot.
AGENT_WALLET_ID=
# Daily spend ceiling for the demo agent, in USD. Never-negative meter cap.
AGENT_DAILY_USD_CAP=5.00
# x402 endpoint allowlist (SSRF guard): comma-separated exact origins.
AGENT_URL_ALLOWLIST=http://localhost:3000
# Caller auth (R-5) — shared secret required as x-internal-secret on /api/agent/pay (the route
# spends real USDC). Blank => route FAILS CLOSED (503 not_configured); SET in production.
AGENT_INTERNAL_SECRET=
# local-dev ONLY — set to "true" to run /api/agent/pay with NO secret (fail-open). NEVER in production.
AGENT_ALLOW_INSECURE=
# Optional caller check (O-10) for /api/ap2/mandate — when set, require it as x-internal-secret. The
# route DERIVES (moves no money), so blank => open; the response carries a prominent on-chain-truth caveat.
AP2_MANDATE_SECRET=

# ── Agent pay-with-any-token quote (anytoken-agent-quote) — SERVER-ONLY, OPTIONAL + ADDITIVE ──
# When a /api/agent/pay body carries `quoteToken`, the route can ALSO answer "what does this
# payment cost in that token?" alongside the untouched USDC settlement. The quote reuses the
# Trading-API transport below (UNISWAP_TRADING_API_URL + UNISWAP_TRADING_API_KEY), so it stays
# DORMANT until that URL is set; any quote error is fail-soft and never blocks settlement.
# Settlement chain the quote prices on. Blank => the any-token quote is OFF (response unchanged).
AGENT_QUOTE_CHAIN_ID=
# Settlement (USDC) token address on AGENT_QUOTE_CHAIN_ID — the quote's tokenOut. Blank => quote OFF.
AGENT_QUOTE_USDC=

# =============================================================================
# Unlink private payout leg (unlink-private) — SERVER-ONLY
# =============================================================================
# Unlink app id — passed to buildDeriveSeedMessage (public, kept here in one place).
UNLINK_APP_ID=
# Unlink secret API key — server-only; createUnlinkAdmin uses this. NEVER ship to client.
UNLINK_API_KEY=
# Unlink environment — literal kebab-case "arc-testnet" (NOT camel "arcTestnet").
UNLINK_ENVIRONMENT=arc-testnet
# Which chain the Unlink shielded set settles on. Blank => Arc Testnet (5042002), the
# DOCUMENTED DEFAULT. Set to another chain id to de-Arc-lock the private rail (per-chain).
NEXT_PUBLIC_UNLINK_CHAIN_ID=
# Shielded USDC token PER CHAIN: NEXT_PUBLIC_UNLINK_USDC_<chainId>. The rail reads the one
# for the active NEXT_PUBLIC_UNLINK_CHAIN_ID. For the Arc default, ARC_TESTNET_USDC below
# is still honoured as the fallback (so existing Arc booth wiring keeps working).
# NEXT_PUBLIC_UNLINK_USDC_5042002=   # Arc Testnet shielded USDC (or use ARC_TESTNET_USDC)
# NEXT_PUBLIC_UNLINK_USDC_84532=     # e.g. Base Sepolia shielded USDC
# Real Arc-testnet USDC token address — Arc-default fallback for the per-chain token above.
# Copy verbatim from lib/arc-constants.ts at the booth.
ARC_TESTNET_USDC=
# Server payout key + bound userId for the fromKeys account (transfer/withdraw only).
UNLINK_PAYOUT_PRIVATE_KEY=
UNLINK_PAYOUT_USER_ID=
# Private AGENT-PAYMENT rail (alternate to the default public x402 spend). "true" turns
# it ON; only takes effect when UNLINK_API_KEY + the per-chain shielded USDC token are also
# set. Blank/any other value => OFF, and /api/agent/pay uses the unchanged public x402 path
# (fail-soft). Edge-unlinkability (shield agent funds, pay merchant from a fresh EOA), NOT a
# mixer. The merchant-facing NEXT_PUBLIC_EARNINGS_PRIVACY knob (below) routes the SAME path.
UNLINK_PRIVATE_PAY=false
# Agent's server payout key for the private rail's fromKeys account (transfer/withdraw
# only, no execute — zero custody). Server-only secret; CONFIRM/OWNER-FILL at the booth.
UNLINK_PRIVATE_PAY_KEY=
# MERCHANT earnings-privacy knob — shield a merchant's payout from competitors. "true"
# routes settlement through the SAME Unlink shield+withdraw path; OFF by default so vanilla
# settlements stay public + verifiable. Takes effect only with UNLINK_API_KEY + the
# shielded USDC token set AND the booth-installed @unlink-xyz/sdk present (else fail-soft to
# the public path — never a claimed shield that did not happen).
NEXT_PUBLIC_EARNINGS_PRIVACY=false

# =============================================================================
# World ID — verified-human checkout option (worldid) — BOOTH-CONFIRM
# The opposite pole of Unlink: prove the payer is a real, unique human
# (proof-of-personhood / Sybil resistance) via IDKit Incognito Actions. NOT the
# retired Sign-in-with-World-ID OIDC (shut down 2026-01-31). Register the app in
# the Developer Portal (https://developer.world.org) — staging AND production —
# to get these values; the signing key is returned ONCE, persist it immediately.
# Blank ⇒ World ID is OFF (the checkout fail-soft degrades to standard).
# =============================================================================
# PUBLIC app id (app_...) — safe in the client bundle (the IDKit widget needs it).
NEXT_PUBLIC_WORLD_APP_ID=
# RP id (rp_...; app_... accepted for back-compat) — PUBLIC; goes in /verify/{rp_id}.
WORLD_RP_ID=
# SERVER-ONLY signing key — signs the RP request in /api/world/sign. NEVER
# NEXT_PUBLIC_, never in a client bundle or the embed (secrets law / guardrail #5).
WORLD_SIGNING_KEY=
# The buyer-gate action string (one human per action). hash(app_id, action) →
# externalNullifier. Register this action in the Developer Portal per environment.
WORLD_ACTION=checkout-verified-human
# IDKit environment — "staging" uses the Worldcoin Simulator (no real Orb needed
# for the demo); flip to "production" for a real World App proof. PUBLIC.
NEXT_PUBLIC_WORLD_ENVIRONMENT=staging
# DISTINCT action strings so the merchant-operator badge and the agent-trial gate
# never consume a buyer's one-per-human slot (separate nullifier spaces).
WORLD_OPERATOR_ACTION=verified-operator
WORLD_AGENT_ACTION=agent-trial-unlock
# Track A (AgentKit): require a verified-human-backed agent for the trial. Off by
# default (fail-soft); set true to gate the agent's first runs behind World ID.
AGENT_REQUIRE_HUMAN=false
# RESERVED (not yet enforced): the intended trial-tier allowance for a verified
# human-backed agent. The gate today only checks personhood; the durable agentMeter
# owns the real budget. Wiring the trial tier is a future money-path change.
AGENT_TRIAL_CALLS=3

# =============================================================================
# OIDC verify-for-all — "Sign in with Google" / any OIDC provider (oidc)
# A generic OIDC verification method: the user signs in with an OIDC provider
# (Google by default, ANY OIDC issuer, or your own auth backend), the browser
# sends the resulting ID token, and /api/oidc/verify checks it server-side
# (signature + issuer + audience) and records the `oidc` method — it stacks into
# Standard -> Verified -> Super Verified alongside World ID / ENS / Dynamic /
# on-chain. "Verify for all": a verified ID token identifies a USER and, when it
# carries an agent claim, a verified AGENT.
# Set NEXT_PUBLIC_OIDC_CLIENT_ID to turn it ON; blank ⇒ OIDC is OFF (fail-soft).
# Defaults verify Sign-in-with-Google ID tokens; override the three OIDC_* vars
# to point at any other OIDC provider or your own backend — no code change.
# =============================================================================
# PUBLIC OIDC client id — the audience the ID token must be issued FOR, and the
# id the browser uses to start the Sign-in-with-Google flow. Blank ⇒ OIDC OFF.
NEXT_PUBLIC_OIDC_CLIENT_ID=
# The OIDC issuer the token's `iss` must match. Default: Google's public issuer.
OIDC_ISSUER=https://accounts.google.com
# The issuer's public JWKS (signing keys) URL. Default: Google's certs endpoint.
OIDC_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs
# SERVER-ONLY audience override (defaults to NEXT_PUBLIC_OIDC_CLIENT_ID when blank).
OIDC_AUDIENCE=
# The token claim that names an agent acting for the user (verify-for-all). Default agent_id.
OIDC_AGENT_CLAIM=agent_id

# =============================================================================
# Durable replay store — anti-replay for World ID nullifiers + OIDC subjects (R-2)
# The one-human-per-action (World ID) and one-account-per-subject (OIDC) gates
# remember every claimed key. In production this MUST be durable: an in-memory
# set is dropped on restart, which would let a spent World ID proof / OIDC token
# be replayed (double-verify / badge-farm). Set a Postgres connection string and
# the gate uses a `UNIQUE(namespace, key)` table (atomic INSERT ... ON CONFLICT).
# Self-hostable — any Postgres, not a managed-service lock-in. Install the `pg`
# optional dependency to use it. The table is created automatically on first use:
#   CREATE TABLE IF NOT EXISTS ax1_replay_claims (
#     namespace TEXT NOT NULL, key TEXT NOT NULL,
#     claimed_at TIMESTAMPTZ NOT NULL DEFAULT now(), UNIQUE (namespace, key));
# Preferred connection var; falls back to DATABASE_URL when this is blank.
NULLIFIER_STORE_URL=
# Shared Postgres URL (used by the replay store when NULLIFIER_STORE_URL is blank).
DATABASE_URL=
# NOTE — the SAME connection string ALSO durably backs the non-security data
# stores (self-onboarded merchant branding + checkout-slug routing, verification
# profiles, issued AI API keys, the agent spend meter). Those stores FAIL SOFT:
# with neither var set they run in-memory and LOSE their data on restart /
# Cloud Run scale-to-zero (a merchant's branding + slug routing vanishes), and
# each emits a one-time boot warning so an operator knows persistence is off.
# Set a Postgres URL here to make branding/verification persistence durable.
# FAIL-CLOSED gate. In production (NODE_ENV=production) the verification path
# REFUSES the in-memory store and returns 503 when no durable store is configured,
# so mainnet can never silently run the replay-vulnerable fallback. Set this to
# "true" to demand the durable store in a NON-production env too (e.g. a staging
# deploy that must behave like prod). Blank/false in dev ⇒ in-memory + loud warn.
VERIFY_REQUIRE_DURABLE_STORE=

# =============================================================================
# ENS merchant identity — ENSIP-19 verified READ + Namestone gasless subname WRITE
# Two OPTIONAL, env-gated seams (lib/ens.ts + lib/ens-subnames.ts). Both fail
# soft: when a var is blank the path is a clean NO-OP — no fabricated name, no
# network call, never a throw (law #4). All names below are PUBLIC standards.
# =============================================================================
# READ — ENSIP-19 verified merchant identity at checkout.
# ENS Universal Resolver address used for the ENSIP-19 reverse() call. A safe
# built-in default ships in code; OVERRIDE here once you CONFIRM the address on
# Etherscan for the network you point at. Blank ⇒ the built-in default is used.
NEXT_PUBLIC_ENS_UNIVERSAL_RESOLVER=    # CONFIRM-ON-ETHERSCAN — leave blank to use the built-in default
# Ethereum MAINNET RPC used SERVER-SIDE for the identity read: recognizing the
# signed-in wallet's own PRIMARY ENS name (coinType 60) for the account chip and
# the /verify prefill. Primary names live on mainnet even in ENSv2. Server-only
# (never exposed to the browser). Blank ⇒ viem's default public mainnet transport
# (the resolver still works keyless; set your own RPC for reliability/rate limits).
MAINNET_RPC_URL=                       # optional — mainnet RPC for primary-name recognition; blank ⇒ public default
# Public, generic ENS parent for onboarding copy / previews ("your own ENS name",
# e.g. yourbrand.eth). Display only — never the WRITE parent below. Blank ⇒ off.
NEXT_PUBLIC_ENS_PARENT=                # OWNER-FILL — your ENS name for display copy (e.g. yourbrand.eth)
# WRITE — Namestone gasless subnames `merchant-<id>.<parent>.eth`.
# Your Namestone API key (server-only secret). Blank ⇒ subname issuance OFF (no-op).
NAMESTONE_API_KEY=                     # OWNER-FILL — Namestone API key; blank ⇒ subname WRITE OFF
# YOUR OWN ENS name used as the subname PARENT (server-only; NEVER hardcoded).
# e.g. yourbrand.eth. Blank ⇒ subname issuance OFF (no-op). Generic by design.
ENS_SUBNAME_PARENT=                    # OWNER-FILL — your ENS name as the subname parent (e.g. yourbrand.eth)
# Optional Namestone API base override; defaults to the public endpoint.
# NAMESTONE_BASE_URL=

# =============================================================================
# Funding seam — get USDC into the buyer/agent wallet (funding/onramp)
# Two ways to top up the connected EOA, BOTH off the money path; the funded USDC
# then flows into the existing pay path (CheckoutCard → payToken). Blank ⇒ the
# funding button is HIDDEN (fail-soft); nothing is ever guessed (law #4).
# =============================================================================

# ── One-tap deposit (one-tap crypto funding layer; SDK = @swype-org/deposit) ──
# Sits ON TOP of the embedded wallet as the funding layer (no copy-address / no
# network-switch). The SDK is installed at the booth and loaded OPTIONALLY at
# click time (lib/funding/loadSdk.ts) — a missing package fails soft.
# Set BLINK_ENABLED=true to turn it on; blank ⇒ OFF. (Server flag, not inlined.)
BLINK_ENABLED=                         # confirm/owner-fill — "true" to enable one-tap deposit
# PUBLIC app/client id the one-tap deposit widget starts with. Blank ⇒ hidden.
NEXT_PUBLIC_BLINK_APP_ID=              # confirm/owner-fill — public app id from the deposit provider
# PUBLIC token the deposit delivers (defaults to USDC, the settlement asset).
NEXT_PUBLIC_BLINK_TOKEN=              # optional — defaults to USDC
# PUBLIC default destination chain id (falls back to NEXT_PUBLIC_DEFAULT_CHAIN_ID).
NEXT_PUBLIC_BLINK_CHAIN_ID=           # optional — defaults to the app's default chain

# ── Fiat on-ramp (provider-agnostic; bank/card → USDC to the EOA) ─────────────
# Which hosted on-ramp runs is chosen by ONRAMP_PROVIDER — NONE hardcoded in code.
# Valid values: coinbase | moonpay | stripe | circle | blink. The hosted base URL
# + public app id come from NEXT_PUBLIC_ONRAMP_*. Blank ⇒ the bank option is HIDDEN.
ONRAMP_PROVIDER=                       # confirm/owner-fill — one of: coinbase, moonpay, stripe, circle, blink
# PUBLIC hosted on-ramp base URL (the provider's widget/checkout origin). Blank ⇒ OFF.
NEXT_PUBLIC_ONRAMP_BASE_URL=          # confirm/owner-fill — provider hosted-checkout base URL
# PUBLIC app/api id the hosted on-ramp identifies this integration by. Blank ⇒ OFF.
NEXT_PUBLIC_ONRAMP_APP_ID=            # confirm/owner-fill — provider public app/api id
# PUBLIC default delivered asset (defaults to USDC, the settlement asset).
NEXT_PUBLIC_ONRAMP_ASSET=            # optional — defaults to USDC
# PUBLIC default delivery network slug (provider-specific, e.g. base / ethereum).
NEXT_PUBLIC_ONRAMP_NETWORK=          # optional — provider network slug
# SERVER-ONLY key some providers need to MINT a session token before redirect.
# NEVER NEXT_PUBLIC_, never placed in a response body or the redirect URL (secrets law).
ONRAMP_SERVER_KEY=                     # optional/server-only — provider session-minting secret

# ── Flow: pay in ANY token → settle USDC (OPTIONAL, default OFF) ───────────────
# Surfaces a "pay in any token" option that swaps the buyer's token into USDC
# (the settlement asset) off the money path; the result then flows into the
# existing pay path. Blank/false ⇒ the option is HIDDEN and nothing changes
# (native/USDC pay as today). TRUTH (law #4): no swap aggregator SDK is wired in
# this repo — the swap STEP is a documented adapter/stub (lib/flow/index.ts) that
# reports `swap_adapter_unavailable`. A named provider here is only the SEAM; no
# token is "swapped"/"settled" until a real SwapAdapter is provided.
NEXT_PUBLIC_FLOW_ENABLED=              # confirm/owner-fill — "true" to surface the pay-in-any-token option
# Which swap aggregator the seam NAMES (SERVER flag, not inlined). Blank ⇒ OFF.
FLOW_PROVIDER=                         # confirm/owner-fill — one of: lifi, uniswap, oneinch, paraswap, 0x
# PUBLIC app/api id the chosen aggregator identifies this integration by. Blank ⇒ hidden.
NEXT_PUBLIC_FLOW_APP_ID=               # confirm/owner-fill — public app/api id from the swap provider
# PUBLIC asset the swap settles INTO (defaults to USDC, the settlement asset).
NEXT_PUBLIC_FLOW_SETTLE_ASSET=         # optional — defaults to USDC
# SERVER-ONLY key some aggregators need to fetch a firm quote / sign a route.
# NEVER NEXT_PUBLIC_, never placed in a response body or a client URL (secrets law).
FLOW_SERVER_KEY=                       # optional/server-only — aggregator quote/route signing secret

# =============================================================================
# ERC-7677 / EIP-5792 sponsored-gas paymaster (paymaster) — CONFIRM FROM OFFICIAL DOCS
# A paymaster covers the network gas cost of a user operation so the payer
# never needs to hold the chain's native gas token. This seam is GENERIC: any
# ERC-7677-compliant paymaster endpoint works (Base / Coinbase / Alchemy / your
# own). The "gas sponsored — you pay $0" badge appears ONLY when both
# NEXT_PUBLIC_PAYMASTER_URL and NEXT_PUBLIC_PAYMASTER_CHAIN_ID are set AND the
# active checkout chain matches that id (law #4 — truth-in-copy, never invent
# sponsorship on a different chain). Blank ⇒ badge is hidden (fail-soft).
# =============================================================================
# SERVER-ONLY feature flag — set "true" to enable sponsorship. Blank ⇒ OFF.
PAYMASTER_ENABLED=                     # owner-fill — "true" to enable sponsored gas
# PUBLIC ERC-7677 JSON-RPC endpoint the wallet calls for pm_getPaymasterStubData
# + pm_getPaymasterData. May include a public project-id path token; NEVER a
# secret key. Example: https://api.developer.coinbase.com/rpc/v1/base-sepolia/<project-id>
NEXT_PUBLIC_PAYMASTER_URL=             # booth-confirm — paymaster JSON-RPC endpoint (public)
# PUBLIC chain id the paymaster operates on. Must match the checkout chain id
# exactly for the badge to appear (no cross-chain sponsorship claim).
NEXT_PUBLIC_PAYMASTER_CHAIN_ID=        # booth-confirm — chain id the endpoint covers (e.g. 84532)

# ── Payout-swap rails (server-only; "Receive In Any Coin") ──────────────────────────
# POST /api/payout-swap swaps settled USDC -> the merchant's payout token on the SAME
# chain, OFF the router (law #5: a failed/unset swap leaves the merchant in USDC). Each
# rail is dormant until its vars are set; an unset rail is skipped (swapped:false), never
# an error. Server-only — NEVER NEXT_PUBLIC_ (these keys must not reach the browser).
UNISWAP_TRADING_API_URL=               # owner-fill — Uniswap Trading API base URL (Base gasless + zkSync classic). Blank => both Uniswap rails OFF
UNISWAP_TRADING_API_KEY=               # owner-fill — Uniswap Trading API x-api-key (server-only). Optional if the URL needs no key
ZKSYNC_SEPOLIA_RPC_URL=                # owner-fill — zkSync Sepolia RPC for the classic-swap submit leg. Blank => zkSync rail OFF (Base unaffected)
BLINK_RPC_URL=                         # optional — BlinkLabs recovery RPC (base.blinklabs.xyz/v1/<key>); tried first on the classic leg, auto-falls back to the direct RPC. Blank => recovery OFF
PAYOUT_SWAP_INTERNAL_SECRET=           # prod — shared secret required as x-internal-secret on /api/payout-swap. Blank => route FAILS CLOSED (503 not_configured); SET in production
PAYOUT_SWAP_ALLOW_INSECURE=            # local-dev ONLY — set to "true" to run /api/payout-swap with NO secret (fail-open). NEVER set in production
# Circle App Kit (Arc rail) stays dormant until @circle-fin/app-kit is installed + wired (see PROGRESS.md).
