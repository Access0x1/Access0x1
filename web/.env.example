# Access0x1 web — public env vars baked into the One-Tag Checkout embed (public/embed.js)
# by scripts/replace-embed-addrs.js at build time. These are PUBLIC addresses
# (NEXT_PUBLIC_*) — no secrets here. Every value is booth-confirmed; leave a
# slot blank until that chain's router/USDC is deployed (the embed falls back
# to the USD-only button label while a slot is empty).

# Arc testnet (chainId 5042002) — the embed's default chain
NEXT_PUBLIC_ROUTER_ARC=
NEXT_PUBLIC_USDC_ARC=

# Base Sepolia (chainId 84532)
NEXT_PUBLIC_ROUTER_BASE_SEPOLIA=
NEXT_PUBLIC_USDC_BASE_SEPOLIA=

# zkSync Sepolia (chainId 300)
NEXT_PUBLIC_ROUTER_ZKSYNC_SEPOLIA=
NEXT_PUBLIC_USDC_ZKSYNC_SEPOLIA=
