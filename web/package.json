{
  "name": "@access0x1/web",
  "version": "0.1.0",
  "private": true,
  "description": "Access0x1 hosted web app (Next.js 16): hosted checkout + PayButton + dashboard (checkout-web), the One-Tag Checkout embed (public/embed.js), the x402 nanopayment seller routes (arc-x402), the server-side Dynamic AI payment agent (dynamic-agent), ENS resolve + name-math (ens-resolve), and the Unlink private payout leg (unlink-private). Zero custody.",
  "license": "MIT",
  "scripts": {
    "dev": "next dev --webpack",
    "prebuild": "node scripts/gen-deployments.mjs && node scripts/gen-module-abis.mjs && node scripts/gen-docs-corpus.mjs && node scripts/replace-embed-addrs.js",
    "gen:deployments": "node scripts/gen-deployments.mjs",
    "gen:abis": "node scripts/gen-module-abis.mjs",
    "gen:docs": "node scripts/gen-docs-corpus.mjs",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "typecheck:e2e": "tsc -p e2e/tsconfig.json --noEmit",
    "test": "vitest run --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run **/*.integration.test.ts",
    "test:watch": "vitest",
    "check:embed": "node --check public/embed.js",
    "verify:embed": "node scripts/verify-embed.js",
    "demo": "tsx scripts/demo-loop.mts",
    "fund": "tsx scripts/fund-gateway.mts",
    "capture:swap": "tsx scripts/capture-payout-swap.mts",
    "gate": "node --check public/embed.js && node scripts/verify-embed.js && node scripts/gen-module-abis.mjs --check && node scripts/gen-docs-corpus.mjs --check && tsc --noEmit && vitest run --exclude '**/*.integration.test.ts'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@circle-fin/x402-batching": "3.2.0",
    "@dynamic-labs-wallet/node-evm": "1.0.81",
    "@dynamic-labs/ethereum": "^4.91.6",
    "@dynamic-labs/sdk-react-core": "^4.91.6",
    "@dynamic-labs/wagmi-connector": "^4.91.6",
    "@radix-ui/react-progress": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.11",
    "@tanstack/react-query": "^5.101.2",
    "@worldcoin/idkit": "^4.2.0",
    "@x402/core": "^2.17.0",
    "@x402/evm": "^2.17.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "next": "^16.2.9",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "viem": "^2.54.3",
    "wagmi": "^2.14.11"
  },
  "optionalDependencies": {
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.2.10",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "ws": "^8.21.0"
  }
}
