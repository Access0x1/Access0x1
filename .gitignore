# Access0x1 — repo .gitignore (staged in the war room; copied to ./.gitignore
# at GO as commit #3, replacing forge-init's Foundry-only default).
# PUBLIC repo + real money: nothing sensitive, ever.

# ── Secrets — NOTHING sensitive, ever ──
.env
.env.*
!.env.example
*.pem
*.key
*.keystore
keystore/
.foundry/
*.secret
mnemonic.txt
secrets.json
# CRE local secrets for `cre workflow simulate` (holds the webhook key VALUE) — never committed.
secrets.yaml
cre/secrets.yaml
# CRE SDK lockfile — generated by the build-session `npm install` in cre/; not part of the contracts gate.
cre/package-lock.json

# ── Foundry / Solidity ──
cache/
out/
# foundry-zksync (zksolc) build output — the zkEVM build artifacts (see docs/ZKSYNC-TESTING.md).
zkout/
# Coverage gate output (`make coverage-lcov`) — machine-readable, regenerated, never committed.
lcov.info
# Audit-tool scratch (regenerated on demand): Halmos cache, Gambit mutants, 4naly3er output.
.halmos_cache/
halmos_cache/
gambit_out/
gambit.conf.json
# aderyn's generated report — curated findings live in audit/FINDINGS.md.
# Scope to the repo-root file aderyn writes; do NOT swallow the committed
# audit report (case-insensitive filesystems would otherwise match REPORT.md).
/report.md
!audit/REPORT.md
# local anvil runs (chainId 31337) — scratch, never the on-chain proof, never committed
broadcast/*/31337/
# dry-run simulations only — KEEP real testnet/mainnet broadcasts (the on-chain deploy proof)
broadcast/**/dry-run/
# NOTE: do NOT ignore lib/ — forge deps are git submodules (.gitmodules is tracked)

# Local, owner-run deploy/register helpers — they hardcode the deployer wallet and are
# never part of the published product (the reproducible path is `make deploy-<chain>`).
/deploy-arc.sh
/deploy-testnets.sh
/register-merchant.sh
/register-barbershop.sh
# npm pack output — the publishable SDK tarball is a build artifact, not source.
*.tgz

# ── Vyper / Moccasin (the ISOLATED vyper/ conformance demonstrator) — Python build artifacts ──
# `out/` and `cache/` above already cover mox/forge artifacts wherever they land. These add the
# Python-side scratch the snake toolchain (boa/pytest/moccasin) writes under vyper/.
__pycache__/
*.pyc
.pytest_cache/
vyper/.cache/
vyper/.venv/
.mypy_cache/

# ── Node / Next.js / SDK ──
node_modules/
.next/
.turbo/
dist/
build/
coverage/
# MetaMask Snaps CLI scratch dir
.snap/
*.tsbuildinfo
.vercel/
.eslintcache
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ── Editor / OS ──
.DS_Store
Thumbs.db
.idea/
*.swp
.vscode/*
!.vscode/extensions.json

# ── War-room guard — these live OUTSIDE the repo; block any accidental copy ──
ethglobal2026/

# Local build tooling + notes — not part of the published product
.claude/
CLAUDE.md
PROGRESS.md

# Local design reference (project snapshot) — NOT part of the published product
linkEvent/
hackathon/
sponsors/
lib-assets/
contract-docs

# Per-chain deploy manifests (name->address) — regenerated by DeployAll on every deploy; the
# committed broadcast is the durable record + the verify-scripts's fallback source.
/deployments/
